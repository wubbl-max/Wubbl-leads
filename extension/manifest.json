{
  "manifest_version": 3,
  "name": "Wubbl Pipeline",
  "version": "1.2",
  "description": "Add LinkedIn posts to your Wubbl pipeline with one click",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Wubbl Pipeline"
  },
  "web_accessible_resources": [
    {
      "resources": ["pipeline-tracker.html", "config.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["file:///*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
